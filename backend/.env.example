# Backend environment template.
# Copy to backend/.env and edit. NEVER commit the real .env (it's gitignored).
#
# After editing, restart `manage.py runserver` for changes to take effect.

# --- Django -----------------------------------------------------------------
# Generate a fresh random key for production:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=changeme-to-random-50-character-string

DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1


# --- MongoDB ----------------------------------------------------------------
# djongo connects to MongoDB at DB_HOST:DB_PORT using DB_NAME.
DB_NAME=medical_platform
DB_HOST=localhost
DB_PORT=27017


# --- CORS -------------------------------------------------------------------
# Comma-separated list of allowed front-end origins.
# The Vite config in this repo defaults to port 3000. If your dev server picks
# a different port (e.g. 5173), add it here.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173


# --- JWT --------------------------------------------------------------------
# Currently hardcoded in core/settings.py SIMPLE_JWT. If you want them
# overridable via .env, add `cast=int` decouple reads in settings.py.
# Defaults shipped in settings.py:
#   ACCESS_TOKEN_LIFETIME  = 60 minutes
#   REFRESH_TOKEN_LIFETIME = 7 days


# --- Uploads ----------------------------------------------------------------
# Hardcoded limits in the upload views (apps/mri/views.py, apps/ecg/views.py):
#   MAX_MRI_SIZE_BYTES = 100 MB
#   MAX_ECG_SIZE_BYTES = 50 MB
# Change them there if you need different caps.


# --- Inference --------------------------------------------------------------
# Heavy model weights download on first inference call to:
#   ~/.cache/torch/hub/                                          (U-Net)
#   ~/.cache/huggingface/                                        (ViT)
#   ~/.cache/torch/hub/checkpoints/12_leads_densenet1d121_*.pt   (ecglib)
# Total: ~700 MB. Keep this disk available.
